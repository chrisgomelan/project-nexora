{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "settings": {
        "color": {
            "palette": [
                {
                    "color": "#072567",
                    "name": "Nexora Navy",
                    "slug": "nexora-navy"
                },
                {
                    "color": "#1A3DAF",
                    "name": "Nexora Blue",
                    "slug": "nexora-blue"
                },
                {
                    "color": "#3F4BE1",
                    "name": "Nexora Accent",
                    "slug": "nexora-accent"
                },
                {
                    "color": "#FFFFFF",
                    "name": "Nexora White",
                    "slug": "nexora-white"
                }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "fontFamily": "Poppins, sans-serif",
                    "name": "Poppins",
                    "slug": "poppins"
                },
                {
                    "fontFamily": "Inter, sans-serif",
                    "name": "Inter",
                    "slug": "inter"
                }
            ]
        },
        "layout": {
            "contentSize": "1140px",
            "wideSize": "1320px"
        }
    },
    "styles": {
        "elements": {
            "h1": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--poppins)",
                    "fontWeight": "700",
                    "fontStyle": "normal",
                    "fontSize": "clamp(32px, 5vw, 64px)",
                    "lineHeight": "1.19",
                    "letterSpacing": "9%",
                    "textTransform": "uppercase"
                },
                "color": {
                    "text": "#072567"
                }
            },
            "h2": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--poppins)",
                    "fontWeight": "700",
                    "fontStyle": "normal",
                    "fontSize": "clamp(24px, 4vw, 38px)",
                    "lineHeight": "1",
                    "letterSpacing": "0"
                },
                "color": {
                    "text": "#072567"
                }
            },
            "h3": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--poppins)",
                    "fontWeight": "600",
                    "fontStyle": "normal",
                    "fontSize": "clamp(20px, 3.5vw, 32px)",
                    "lineHeight": "1",
                    "letterSpacing": "0"
                },
                "color": {
                    "text": "#072567"
                }
            },
            "h4": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--poppins)",
                    "fontWeight": "400",
                    "fontStyle": "normal",
                    "fontSize": "clamp(18px, 2.5vw, 24px)",
                    "lineHeight": "1",
                    "letterSpacing": "1%",
                    "textAlign": "center"
                },
                "color": {
                    "text": "#072567"
                }
            },
            "h5": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--poppins)",
                    "fontWeight": "400",
                    "fontStyle": "normal",
                    "fontSize": "clamp(16px, 2vw, 18px)",
                    "lineHeight": "1",
                    "letterSpacing": "0"
                },
                "color": {
                    "text": "#072567"
                }
            },
            "p": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--poppins)",
                    "fontWeight": "400",
                    "fontStyle": "normal",
                    "fontSize": "clamp(16px, 2.5vw, 24px)",
                    "lineHeight": "1.5",
                    "letterSpacing": "0"
                },
                "color": {
                    "text": "#072567"
                }
            },
            "cite": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--poppins)",
                    "fontWeight": "300",
                    "fontStyle": "italic",
                    "fontSize": "16px",
                    "lineHeight": "1",
                    "letterSpacing": "0",
                    "textAlign": "center"
                },
                "color": {
                    "text": "#072567"
                }
            }
        },
        "blocks": {
            "core/paragraph": {
                "typography": {
                    "lineHeight": "1.5"
                }
            },
            "core/navigation": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--poppins)",
                    "fontWeight": "500",
                    "fontStyle": "normal",
                    "fontSize": "20px",
                    "lineHeight": "1",
                    "letterSpacing": "0",
                    "textTransform": "uppercase"
                },
                "color": {
                    "text": "#072567"
                }
            },
            "core/template-part": {
                "variations": {
                    "header": {
                        "color": {
                            "background": "var(--wp--preset--color--nexora-white)"
                        },
                        "spacing": {
                            "padding": {
                                "top": "0",
                                "bottom": "0",
                                "left": "0",
                                "right": "0"
                            }
                        },
                        "blocks": {
                            "core/navigation": {
                                "typography": {
                                    "fontFamily": "var(--wp--preset--font-family--poppins)",
                                    "fontWeight": "500",
                                    "fontStyle": "normal",
                                    "fontSize": "20px",
                                    "lineHeight": "1",
                                    "letterSpacing": "0",
                                    "textTransform": "uppercase"
                                },
                                "color": {
                                    "text": "#072567"
                                }
                            }
                        }
                    },
                    "footer": {
                        "blocks": {
                            "core/navigation": {
                                "typography": {
                                    "fontFamily": "var(--wp--preset--font-family--inter)",
                                    "fontWeight": "500",
                                    "fontStyle": "normal",
                                    "fontSize": "20px",
                                    "lineHeight": "1",
                                    "letterSpacing": "0"
                                },
                                "color": {
                                    "text": "#072567"
                                }
                            }
                        }
                    }
                }
            },
            "core/button": {
                "variations": {
                    "nexora-primary": {
                        "typography": {
                            "fontFamily": "var(--wp--preset--font-family--poppins)",
                            "fontWeight": "600",
                            "fontStyle": "normal",
                            "fontSize": "15px",
                            "lineHeight": "1",
                            "letterSpacing": "0",
                            "textAlign": "justify"
                        },
                        "color": {
                            "text": "#FFFFFF",
                            "background": "#072567"
                        },
                        "border": {
                            "radius": "10px"
                        },
                        "spacing": {
                            "padding": {
                                "top": "14px",
                                "bottom": "14px",
                                "left": "24px",
                                "right": "24px"
                            }
                        }
                    },
                    "nexora-secondary": {
                        "typography": {
                            "fontFamily": "var(--wp--preset--font-family--poppins)",
                            "fontWeight": "600",
                            "fontStyle": "normal",
                            "fontSize": "15px",
                            "lineHeight": "1",
                            "letterSpacing": "0"
                        },
                        "color": {
                            "text": "#072567",
                            "background": "transparent"
                        },
                        "border": {
                            "color": "#072567",
                            "width": "1px",
                            "style": "solid",
                            "radius": "10px"
                        },
                        "spacing": {
                            "padding": {
                                "top": "20px",
                                "bottom": "20px",
                                "left": "39px",
                                "right": "39px"
                            }
                        }
                    }
                }
            }
        }
    }
}